<div class="container py-4">
  <div class="mb-3">
    <h1 class="mb-1"><%= @project.respond_to?(:title) ? @project.title : @project.name %></h1>
    <% desc = @project.respond_to?(:description) ? @project.description : @project.content %>
    <p class="text-muted"><%= simple_format(desc.to_s) %></p>
  </div>

  <hr>

  <% if @chat.nil? %>
    <%= button_to "Démarrer le chat IA",
          project_chats_path(@project),
          method: :post,
          class: "btn btn-primary" %>
  <% else %>
    <div class="border rounded p-3 mb-3" style="min-height: 240px;">
      <% @messages.each do |m| %>
        <div class="mb-3">
          <div class="small text-muted"><%= m.role == "assistant" ? "Assistant" : "Moi" %></div>
          <div><%= simple_format(m.content) %></div>
        </div>
      <% end %>

      <% if @messages.empty? %>
        <p class="text-muted mb-0">Aucun message pour l’instant.</p>
      <% end %>
    </div>

    <%= form_with model: [@chat, @message] do |f| %>
      <div class="mb-2">
        <%= f.text_area :content, rows: 3, class: "form-control", placeholder: "Écris ton message..." %>
      </div>
      <div class="d-flex gap-2">
        <%= f.submit "Envoyer", class: "btn btn-primary" %>

        <%= button_to "Supprimer le chat",
              chat_path(@chat),
              method: :delete,
              class: "btn btn-outline-danger",
              form: { data: { turbo_confirm: "Supprimer ce chat ?" } } %>
      </div>
    <% end %>
  <% end %>
</div>
