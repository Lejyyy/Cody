<div class="container py-5">
  <h1 class="mb-2">Cody — AI Assistant
    <img src="codemate.svg" alt="Logo de Cody" width="40" height="40" class="ms-2">
  </h1>
  <p class="text-muted mb-4">
    Décris ton projet web, et l'assistant te propose un MVP, une stack et une roadmap.
  </p>

  <% if user_signed_in? %>
    <div class="d-flex gap-2">
      <%= link_to "Voir mes projets", projects_path, class: "btn btn-primary" %>
      <%= link_to "Se déconnecter", destroy_user_session_path, method: :delete, class: "btn btn-danger" %>
    </div>
  <% else %>
    <div class="d-flex gap-2">
      <%= link_to "Se connecter", new_user_session_path, class: "btn btn-primary" %>
      <%= link_to "Créer un compte", new_user_registration_path, class: "btn btn-outline-primary" %>
    </div>
  <% end %>
</div>



